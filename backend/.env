# Environment Variables
NODE_ENV=development
PORT=5000

# Database - Local MongoDB (IPv4 localhost)
MONGODB_URI=mongodb://127.0.0.1:27017/bidcraft
MONGODB_ATLAS_URI=mongodb+srv://bidcraft:bidcraft123@cluster0.oy8bkgv.mongodb.net/bidcraft?retryWrites=true&w=majority&appName=Cluster0
# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production_make_it_very_long_and_random
JWT_EXPIRE=7d

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email (NodeMailer)
EMAIL_FROM=noreply@bidcraft.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Security
BCRYPT_ROUNDS=12

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Auction Settings
AUCTION_EXTENSION_TIME=300000
BID_INCREMENT_PERCENTAGE=5
